# ──────────────────────────────────────────────
# Azure Identity / Service Principal
# ──────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ──────────────────────────────────────────────
# Storage (Azure Table Storage for cost data)
# ──────────────────────────────────────────────
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=yourstore;AccountKey=...;EndpointSuffix=core.windows.net

# ──────────────────────────────────────────────
# Logic App Webhook URLs (Alerting)
# ──────────────────────────────────────────────
LOGIC_APP_SLACK_WEBHOOK_URL=https://your-logic-app.azurewebsites.net/api/slack
LOGIC_APP_TEAMS_WEBHOOK_URL=https://your-logic-app.azurewebsites.net/api/teams

# ──────────────────────────────────────────────
# Cost Thresholds & Governance
# ──────────────────────────────────────────────
DAILY_BUDGET_LIMIT=500
MONTHLY_BUDGET_LIMIT=15000
COST_ANOMALY_THRESHOLD_PERCENT=20
WASTE_ALERT_MIN_SAVINGS=50

# ──────────────────────────────────────────────
# Grafana (local development)
# ──────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=admin
